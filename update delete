#include "DeleteAccountDialog.h"
#include "LoginDialog.h"
#include "SignupDialog.h"
#include "../core/UserManager.h"

void MainWindow::deleteAccount()
{
    QString user = UserManager::currentUser();

    DeleteAccountDialog dialog(this);

    if (dialog.exec() != QDialog::Accepted)
        return;

    QString password = dialog.password();

    if (!UserManager::deleteUser(user, password))
    {
        QMessageBox::warning(this,
            "Error",
            "Incorrect password.");
        return;
    }

    QMessageBox::information(this,
        "Account Deleted",
        "Your account has been deleted.");

    ui->tabWidget->clear();

    // Decide next step
    if (UserManager::users().isEmpty())
    {
        SignupDialog signup;

        if (signup.exec() != QDialog::Accepted)
        {
            close();
            return;
        }
    }

    LoginDialog login;

    if (login.exec() != QDialog::Accepted)
    {
        close();
        return;
    }

    // Reload preferences
    QString newUser = UserManager::currentUser();

    QFont font = SettingsManager::loadFontPreferences(newUser);
    bool wrap = SettingsManager::loadWordWrap(newUser);

    m_customToolbar->setFont(font);
    ui->actionWordWrap->setChecked(wrap);
}
